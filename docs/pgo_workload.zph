fn fib(n: Int) -> Int {
    if n <= 1 { return n; }
    return fib(n - 1) + fib(n - 2);
}

fn sum_loop(limit: Int) -> Int {
    let total = 0;
    let i = 0;
    while i < limit {
        total = total + i;
        i = i + 1;
    }
    return total;
}

fn main() -> Int {
    let a = fib(20);
    let b = sum_loop(100000);
    return a + b;
}
