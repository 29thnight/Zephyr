import "engine" as engine;

fn on_player_damaged(amount: int) -> int {
    engine.log("event.damage", amount);
    return amount + 3;
}

fn on_faulty_damage(amount: int) -> int {
    assert(amount < 0);
    return amount;
}

fn main() {
    register_damage_handler("on_player_damaged");
    register_failure_handler("on_faulty_damage");
    engine.log("handlers", "registered");
}
